{
  "name": "financial-tracker",
  "version": "1.0.0",
  "description": "Financial tracking web application with NocoDB integration",
  "main": "server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "pm2:start": "pm2 start infrastructure/ecosystem.config.js",
    "pm2:stop": "pm2 stop infrastructure/ecosystem.config.js",
    "pm2:restart": "pm2 restart infrastructure/ecosystem.config.js",
    "pm2:logs": "pm2 logs",
    "db:setup": "node backend/scripts/setupNocodb.js",
    "db:seed": "node backend/scripts/seedData.js",
    "db:check": "node backend/scripts/checkData.js",
    "test": "cross-env NODE_ENV=test FIREBASE_SERVICE_ACCOUNT_KEY_JSON='{\"project_id\":\"mock-project\"}' CATEGORIES_TABLE_ID=mock_table mocha 'backend/tests/**/*.test.js'",
    "test:email": "node backend/tests/manual_email_test.js",
    "test:ui": "vitest run --config vite.config.mjs",
    "build": "vite build",
    "lint:js": "eslint '**/*.{js,mjs,vue}'",
    "lint:css": "stylelint 'frontend/src/**/*.css'",
    "lint:md": "markdownlint '**/*.md' --ignore node_modules",
    "lint:json": "eslint '**/*.json' --no-error-on-unmatched-pattern",
    "lint:all": "pnpm run lint:js && pnpm run lint:css && pnpm run lint:md && pnpm run lint:json",
    "lint:unused": "knip",
    "lint:deps": "depcheck",
    "analyze": "pnpm run lint:unused && pnpm run lint:deps",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{js,mjs,vue,json}": "eslint --fix",
    "**/*.css": "stylelint --fix",
    "**/*.md": "markdownlint --fix"
  },
  "keywords": [
    "financial",
    "tracker",
    "nocodb",
    "web-app"
  ],
  "author": "Niyaz Almufti",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@primevue/core": "^4.5.5",
    "@primevue/themes": "^4.5.4",
    "axios": "^1.16.1",
    "chart.js": "^4.5.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase": "^12.14.0",
    "firebase-admin": "^14.0.0",
    "handlebars": "^4.7.9",
    "morgan": "^1.11.0",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.0",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@primevue/auto-import-resolver": "^4.5.5",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.3.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.1",
    "eslint-plugin-json-format": "^2.0.1",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "markdownlint-cli": "^0.48.0",
    "mocha": "^11.7.6",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.15",
    "postcss-cli": "^11.0.1",
    "proxyquire": "^2.1.3",
    "sinon": "^22.0.0",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.3.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vue-eslint-parser": "^10.4.1",
    "@vue/test-utils": "^2.4.6",
    "depcheck": "^1.4.7",
    "knip": "^6.16.1"
  }
}
